<?php

/**
 * Aixada configuration file.
 *
 * Copy this file to local_config/config.php and fill in your values.
 * local_config/config.php is gitignored and must never be committed.
 *
 * The constructor detects the environment via HTTP_HOST and sets
 * database credentials and other per-environment values accordingly.
 *
 * @package Aixada
 */

class configuration_vars {

    /*******************************************************************
        Here begin the variables you must set during installation.
    ********************************************************************/

    /**
     * Default language for the interface.
     * Available: 'ca-va', 'es', 'en'
     * @var string
     */
    public $default_language = 'ca-va';

    /**
     * What is the name of this cooperative?
     * @var string
     */
    public $coop_name = 'My Cooperative';

    // Show coop name on header of login.php
    public $login_header_show_name = false;

    // Header image used in login.php. Set to false to not use image.
    public $login_header_image = 'local_config/custom_img/our_cooperative_banner.jpg';

    // Used in Report headers. Set to false to not use logo.
    public $coop_header_logo = 'local_config/custom_img/our_cooperative_logo.png';

    public $coop_VAT_number = 'F9999999'; // CIF
    public $coop_address    = 'Street...';
    public $coop_city       = 'Zip City';
    public $coop_bank       = 'IBAN';
    public $coop_contact_inf = 'email@example.com<br>...'; // Use <br> to force line break


    /*******************************************************************
        Database credentials — set per environment in the constructor.
        Declared here to avoid PHP 8.2 dynamic property deprecation.
    ********************************************************************/

    /** @var string */
    public $db_host     = '';
    /** @var string */
    public $db_name     = '';
    /** @var string */
    public $db_user     = '';
    /** @var string */
    public $db_password = '';


    /****************************************************************************
       You should not need to change anything past this point when installing.
    ****************************************************************************/

    /**
     * Indicates whether the store is used. Possible values are:
     *    - 'order_and_stock': The shop is shown with all active products (default)
     *    - 'only_stock':      The shop is shown only with active stock products.
     *    - false:             The shop is not shown.
     * @var string|boolean
     */
    public $use_shop = 'order_and_stock';

    /**
     * Allows allocate losses order distribution to a fictitious family (when the
     * review is done). Uncomment to activate.
     * @var integer
     */
    // public $revision_fixed_uf = 1;

    /**
     * Allow yourself validate your cart.
     * (if it is not set `false` is used as default value)
     * @var boolean
     */
    public $validate_self = false;

    /**
     * After a cart validation shows warning message if no deposit has been made.
     * (if it is not set `true` is used as default value)
     * @var boolean
     */
    public $validate_deposit = true;

    /**
     * What period are shown the carts on validation, values allowed: 'day'
     * or 'week', default value is 'day'.
     * @var string
     */
    public $validate_show_carts = 'day';

    /**
     * Allows create an empty cart at validation.
     * If true a button "Create cart" is displayed when a UF has no validated carts.
     * @var boolean
     */
    public $validate_btn_create_carts = false;

    /**
     * Sets the max. time scale for activating orderable dates into the future.
     * E.g. 12 means orderable dates for the next year can be generated in advance.
     * @var integer
     */
    public $max_month_orderable_dates = 12;

    /**
     * Display warnings when a UF has a negative balance.
     * Set to false to block access to shop/order pages when balance is negative.
     * @var boolean
     */
    public $allow_negative_balances = true;

    /**
     * In days, the amount of time one UF can purchase without being blocked.
     * Has effect only if `$allow_negative_balances` is set to false.
     * @var integer
     */
    public $negative_balance_grace_periode = 14;

    /**
     * List of pages to block when a UF has a negative balance.
     * @var array
     */
    public $negative_balance_disabled_pages = array('index.php', 'shop_and_order.php');

    /**
     * Prevents purchase of products with no stock (used in shop_and_order.php).
     * @var boolean
     */
    public $prevent_out_of_stock_purchase = true;

    /**
     * Allows putting stock products into a UF order.
     * @var boolean
     */
    public $orders_allow_stock = false;

    /**
     * Order in which UFs are displayed when reviewing and printing orders.
     * Possible values: 'asc', 'desc', 'name'. Default: 'desc'.
     * @var string
     */
    public $order_review_uf_sequence = 'desc';

    /**
     * Method for distributing orders.
     * Possible values: 'only_distribute', 'distribute_and_validate', 'choice'.
     * @var string
     */
    public $order_distribution_method = 'only_distribute';

    /**
     * When 'distribute_and_validate' is used, also record provider note as
     * invoice into account provider. Default: true.
     * @var boolean
     */
    public $order_distributeValidate_invoce = true;

    /**
     * The default jQuery UI theme. Themes are in css/ui-themes/.
     * @var string
     */
    public $default_theme = 'smoothness'; // start | ui-lightness | smoothness | redmond

    /**
     * Backup method. By default the script is used; if it fails due to host
     * restrictions the internal method is used.
     * To force internal method: uncomment the line below.
     * @var string
     */
    // public $db_backup_method = 'int';

    /**
     * System-wide currency symbol and type.
