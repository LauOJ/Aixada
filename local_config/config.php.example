    /**
     * How to use accounts.
     * With 'use_providers' = false, provider account operations are disabled.
     */
    public $accounts = array(
        'use_providers' => false
    );


    // from here on follow internals of the configuration_vars class.
    private static $instance = false;

    public function __construct()
    {
        $host = $_SERVER['HTTP_HOST'] ?? '';

        // LOCAL (Docker)
        if (strpos($host, 'localhost') !== false || strpos($host, '127.0.0.1') !== false) {

            $this->db_host            = 'mariadb';  // or 'mysql', depends on docker-compose service name
            $this->db_name            = 'aixada';
            $this->db_user            = 'aixada';
            $this->db_password        = 'your_local_password';
            $this->internet_connection = false;

        // STAGING
        } elseif (strpos($host, 'proves.example.org') !== false) {

            $this->db_host     = 'localhost';
            $this->db_name     = 'aixada_proves';
            $this->db_user     = 'aixada';
            $this->db_password = 'your_staging_password';

        // PRODUCTION
        } elseif (strpos($host, 'example.org') !== false) {

            $this->db_host     = 'localhost';
            $this->db_name     = 'aixada';
            $this->db_user     = 'aixada';
            $this->db_password = 'your_production_password';

        } else {

            // Safe fallback — prevents running with unknown configuration
            die('Unknown environment. Check your config.php HTTP_HOST detection.');
        }
    }

    public static function get_instance()
    {
        if (self::$instance === false)
            self::$instance = new configuration_vars();
        return self::$instance;
    }
}
