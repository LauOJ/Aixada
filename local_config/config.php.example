     */
    public $currency_sign    = '€';
    public $currency_iso     = 'EUR';
    public $currency_type_id = 1;

    /**
     * Formats used for dates and numbers.
     */
    public $type_formats = array(
        'dates' => array(
            'date'      => 'd-m-Y',
            'datetime'  => 'd-m-Y H:i',
            'timestamp' => true,
        ),
        'numbers' => array(
            'amount' => '2.',
            'locale' => 'es-ES'
        )
    );

    /**
     * Sequence Ajax requests to reduce server load on low-resource hosting.
     * Uncomment to activate.
     */
    // public $use_ajaxQueue = true;

    /**
     * The email address of the admin; used for password recovery and orders.
     * @var string
     */
    public $admin_email = 'admin@example.com';

    /**
     * Set true to prevent false locks as SPAM when sending mails.
     * @var boolean
     */
    public $email_safe_replyTo = true;

    /**
     * Email SMTP options. Uncomment and fill in to use SMTP via swiftmailer.
     */
    // public $email_SMTP_host       = 'smtp.example.com';
    // public $email_SMTP_port       = 587;
    // public $email_SMTP_user       = 'user';
    // public $email_SMTP_pswd       = 'password';
    // public $email_SMTP_encryption = 'tls'; // 'ssl', 'tls', or null
    // public $email_SMTP_verifyCert = true;

    /**
     * Is this instance accessible online?
     * Set to false for local development to disable email sending.
     * Overridden per environment in the constructor.
     * @var boolean
     */
    public $internet_connection = true;

    /**
     * SSO integration with WordPress.
     * Set cookie_domain to the shared domain (e.g. '.example.org') to allow
     * the Aixada session cookie to be read by WordPress on the same domain.
     * Set wp_auth_secret to the HMAC secret shared with the WordPress plugin.
     * Leave both empty if WordPress integration is not used.
     */
    public $cookie_domain  = '';
    public $wp_auth_secret = '';

    /**
     * Optional URL of a custom dashboard shown after login.
     * Displayed as the "Torna al tauler" link in the menu (if set).
     * Leave empty if no custom dashboard is used.
     * Set per environment in the constructor (full URL with hostname).
     * @var string
     */
    public $dashboard_url = '';

    /**
     * Page to redirect to after a successful login.
     * Use 'dashboard.php' if a custom dashboard exists, or 'aixada_main.php'
     * to go directly to the Aixada (default for cooperatives without a dashboard).
     * @var string
     */
    public $post_login_redirect = 'aixada_main.php';


    /**
     * HTML print templates.
     */
    public $print_order_template    = 'report_order1.php';
    public $print_my_orders_template = 'order_model1.php';
    public $print_bill_template     = 'bill_model1.php';
    public $print_incidents_template = 'incidents_model1.php';

    /**
     * Display the language selector in the menu.
     * @var boolean
     */
    public $show_menu_language_select = false;


    /**
     * ORDER REPORT VARS
     */

    /**
     * If true, finalized orders are emailed directly to providers.
     * Only works on servers with appropriate PHP mail configuration.
     * @var boolean
     */
    public $email_orders = false;

    /**
     * Default format of emailed orders:
     *  - 'Prod', '1':    List of products (summarized)
     *  - 'Matrix', '2':  Grid products-UF (extended)
     *  - 'Prod_Matrix', 3: List of products + Grid
     *  - 'ProdUf':       List of products with UF detail
     *  - 'Prod_ProdUf':  List of products + List with UF detail
     *  - 'UfProd':       List of UF with product detail
     *  - 'none':         Do not send
     */
    public $email_order_format = 3;

    /**
     * Default prices used on emailed orders:
     *  - 'cost_amount': Price and cost amount (without tax)
     *  - 'cost':        Cost amount (without tax)
     *  - 'none':        Without cost
     */
    public $email_order_prices = 'cost_amount';


    /**
     * INCIDENTS REPORTING
     */

    /**
     * Distribution list for incident emails.
     * If empty, incidents are sent to individual user email addresses.
     * @var string
     */
    public $incidents_email_list = '';
    public $incidents_mail_list  = '';


    /**
     * CALENDARI / TORNS MODULE
     */

    /**
     * Enable or disable the shift calendar module. Default: false.
